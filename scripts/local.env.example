# Local WordPress + Next.js dev (copy to scripts/local.env — never commit local.env)

PROJECT_SLUG=thesibook-booking-shine

# Full WordPress URL (no trailing slash) — adjust for MAMP port if needed
WP_LOCAL_URL=http://localhost/thesibook-booking-shine/backend

# MySQL (defaults match install-wordpress.sh)
DB_NAME=thesibook_booking_shine_backend
DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost

# wp core install (first time only)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=dev@localhost.test
WP_SITE_TITLE="ThesiBook Local"

# Next.js origin (CORS)
WEBCODE_FRONTEND_URL=http://localhost:3000

# Seed on fresh install (true | false)
LOCAL_WP_SEED=true
