# Production book/ env — copy to scripts/deploy/book.env (never commit)

# Reuse main deploy SSH settings or override:
# DEPLOY_SSH=webcode@your-server.de
# DEPLOY_SSH_PORT=222
# DEPLOY_REMOTE_ROOT=/usr/home/webcode/thesibook-booking-shine

BOOK_REMOTE_PATH=${DEPLOY_REMOTE_ROOT}/book

# Easy!Appointments production URL (no trailing slash)
EA_BASE_URL=https://book.yourdomain.com

EA_DB_HOST=localhost
EA_DB_NAME=thesibook_ea
EA_DB_USER=thesibook_ea
EA_DB_PASSWORD=change-me
EA_DEBUG_MODE=false

# PHP-FPM socket or host (for nginx template)
PHP_FPM_SOCK=/run/php/php8.2-fpm.sock
