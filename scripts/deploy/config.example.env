# Copy to scripts/deploy/.env before production deploy (never commit .env with real secrets)

# SSH — test: ssh -p 222 USER@HOST
DEPLOY_SSH=webcode@dedi3543.your-server.de
DEPLOY_SSH_PORT=222

# Server home (only .../thesibook-booking-shine/ is updated)
DEPLOY_REMOTE_ROOT=/usr/home/webcode
DEPLOY_PROJECT_DIR=thesibook-booking-shine

DEPLOY_SERVER_USER=webcode
DEPLOY_SERVER_GROUP=webcode

# wp-cli on server (adjust path if needed)
DEPLOY_WP_CLI=/usr/home/webcode/.linuxbrew/bin/wp

# Docroot — CMS at https://thesibook.gr/thesibook-booking-shine/backend/
DEPLOY_PUBLIC_HTML=/usr/home/webcode/public_html
DEPLOY_LINK_PUBLIC_HTML=true

# Live URLs (ThesiBook production)
WORDPRESS_API_URL=https://thesibook.gr/thesibook-booking-shine/backend/wp-json/webcode/v1
NEXT_PUBLIC_SITE_URL=https://thesibook.gr
WORDPRESS_MEDIA_HOSTNAME=thesibook.gr
WEBCODE_HEADLESS_CORS_ORIGINS=https://thesibook.gr,https://www.thesibook.gr

# MySQL — create database in hosting panel first
WP_DB_NAME=CHANGE_ME_db
WP_DB_USER=CHANGE_ME_user
WP_DB_PASSWORD=CHANGE_ME_password
WP_DB_HOST=CHANGE_ME_host

# First wp core install only (wp-config.php on server is never overwritten by rsync)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=CHANGE_ME
WP_ADMIN_EMAIL=hello@thesibook.gr
WP_SITE_TITLE=ThesiBook

DEPLOY_WP_SETUP=true
# true = always re-seed CMS from repo | auto = same | false = never seed
DEPLOY_WP_SEED=true

DEPLOY_NODE_PORT=3002
NEXT_RENDER_MODE=isr

# DEPLOY_SKIP_BACKEND=false
# DEPLOY_SKIP_FRONTEND=false
# DEPLOY_YES=true
