# Copy to scripts/deploy/.env before production deploy (never commit .env with real secrets)
#
# ThesiBook dedicated server (thesiu @ dedi3543) — NOT the webcode.gr account.

# SSH — test: ssh -p 222 thesiu@dedi3543.your-server.de
DEPLOY_SSH=thesiu@dedi3543.your-server.de
DEPLOY_SSH_PORT=222

# Only ${DEPLOY_REMOTE_ROOT}/${DEPLOY_PROJECT_DIR}/ is touched (never webcode paths)
DEPLOY_REMOTE_ROOT=/usr/home/thesiu
DEPLOY_PROJECT_DIR=thesibook-booking-shine

DEPLOY_SERVER_USER=thesiu
DEPLOY_SERVER_GROUP=thesiu

DEPLOY_WP_CLI=/usr/home/thesiu/bin/wp

DEPLOY_PUBLIC_HTML=/usr/home/thesiu/public_html
DEPLOY_LINK_PUBLIC_HTML=true

# Split hosting
# Public site (Next.js): https://www.thesibook.gr  → Node port DEPLOY_NODE_PORT
# CMS + API (WordPress): https://thesibook.gr/thesibook-booking-shine/backend/
WORDPRESS_API_URL=https://thesibook.gr/thesibook-booking-shine/backend/wp-json/webcode/v1
NEXT_PUBLIC_SITE_URL=https://www.thesibook.gr
WORDPRESS_MEDIA_HOSTNAME=thesibook.gr
WEBCODE_HEADLESS_CORS_ORIGINS=https://www.thesibook.gr,https://thesibook.gr

# MySQL — on server use localhost (not lpb1.your-database.de)
WP_DB_NAME=thesiu_db0
WP_DB_USER=thesiu_0
WP_DB_PASSWORD=CHANGE_ME
WP_DB_HOST=localhost

WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=CHANGE_ME
WP_ADMIN_EMAIL=hello@thesibook.gr
WP_SITE_TITLE=ThesiBook

DEPLOY_WP_SETUP=true
DEPLOY_WP_SEED=false

DEPLOY_NODE_PORT=3005
NEXT_RENDER_MODE=isr

# DEPLOY_SKIP_BACKEND=false
# DEPLOY_SKIP_FRONTEND=false
# DEPLOY_YES=true
