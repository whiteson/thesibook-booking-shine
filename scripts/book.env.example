# Easy!Appointments — local + production (copy to scripts/book.env)

# --- Mode: native (PHP + MariaDB/MySQL on host) — default for dev and production server ---
BOOK_MODE=native

EA_BASE_URL=http://localhost:8090
EA_DB_HOST=localhost
EA_DB_NAME=thesibook_ea
EA_DB_USER=root
EA_DB_PASSWORD=password
EA_DEBUG_MODE=true

# Dev only: PHP built-in server port (./scripts/install-book.sh --serve)
EA_DEV_PORT=8090

# --- Optional: Docker (local only, if you install Docker Desktop) ---
# BOOK_MODE=docker
# NGINX_PORT=8090
# MYSQL_PORT=3307
# PHPMYADMIN_PORT=8091

# --- Production (fill on server scripts/deploy/book.env) ---
# EA_BASE_URL=https://book.yourdomain.com
# EA_DB_HOST=localhost
# EA_DB_NAME=thesibook_ea_prod
# EA_DEBUG_MODE=false
